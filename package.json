{
  "name": "jetbrains-titlebar",
  "displayName": "JetBrains Titlebar",
  "description": "A VS Code extension that adds backgroundColor(generated by your project name) to the title bar",
  "description_zh": "一个可以自动计算标题栏颜色的 VS Code 扩展，计算依据是你的项目文件夹名称、目录或日期（可自选）",
  "version": "1.1.0",
  "purpose": "vscode-extension",
  "publisher": "KasukabeTsumugi",
  "engines": {
    "vscode": "^1.74.0"
  },
  "author": {
    "email": "futami16237@gmail.com",
    "name": "Kasukabe Tsumugi"
  },
  "categories": [
    "Themes"
  ],
  "keywords": [
    "titlebar",
    "color",
    "theme",
    "project",
    "workspace",
    "customization"
  ],
  "homepage": "https://github.com/baendlorel/jetbrains-titlebar#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/baendlorel/jetbrains-titlebar.git"
  },
  "bugs": {
    "url": "https://github.com/baendlorel/jetbrains-titlebar/issues"
  },
  "license": "MIT",
  "icon": "assets/idea.png",
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "jetbrains-titlebar.applyGlow",
        "title": "%command.applyGlow.title%",
        "category": "%extension.category%"
      },
      {
        "command": "jetbrains-titlebar.removeGlow",
        "title": "%command.removeGlow.title%",
        "category": "%extension.category%"
      },
      {
        "command": "jetbrains-titlebar.manuallyRelocateCssPath",
        "title": "%command.manuallyRelocateCssPath.title%",
        "category": "%extension.category%"
      },
      {
        "command": "jetbrains-titlebar.autoRelocateCssPath",
        "title": "%command.autoRelocateCssPath.title%",
        "category": "%extension.category%"
      }
    ],
    "configuration": {
      "title": "%configuration.title%",
      "properties": {
        "jetbrains-titlebar.showProjectInitials": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.showProjectInitials.description%"
        },
        "jetbrains-titlebar.cssPath": {
          "type": "object",
          "default": {},
          "description": "%configuration.cssPath.description%"
        },
        "jetbrains-titlebar.glowIntensity": {
          "type": "number",
          "default": 32,
          "minimum": 0,
          "maximum": 100,
          "description": "%configuration.glowIntensity.description%"
        },
        "jetbrains-titlebar.glowDiameter": {
          "type": "number",
          "default": 260,
          "minimum": 0,
          "maximum": 2000,
          "description": "%configuration.glowDiameter.description%"
        },
        "jetbrains-titlebar.glowOffsetX": {
          "type": "number",
          "default": 120,
          "minimum": 0,
          "maximum": 2000,
          "description": "%configuration.glowOffsetX.description%"
        },
        "jetbrains-titlebar.colorSeed": {
          "type": "string",
          "default": "",
          "description": "%configuration.colorSeed.description%"
        }
      }
    }
  },
  "scripts": {
    "lines": "clear && find ./src -type f \\( -name \"*.ts\" -o -name \"*.tsx\" -o -name \"*.js\" -o -name \"*.mjs\" -o -name \"*.cjs\" -o -name \"*.cpp\" -o -name \"*.h\" -o -name \"*.py\"  -o -name \"*.css\" -o -name \"*.rs\" -o -name \"*.rc\" \\) | xargs wc -l",
    "test-build": "rimraf out && export NODE_ENV=dev && tsx ./.scripts/rollup.ts",
    "build": "rimraf out &&  tsx ./.scripts/rollup.ts",
    "watch": "tsc -watch -p ./",
    "check": "tsc -p tsconfig.build.json",
    "lint": "oxlint .",
    "pub": "vsce package -o ./bin",
    "publish": "pnpm build && vsce publish"
  },
  "devDependencies": {
    "@rollup/plugin-alias": "^6.0.0",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-replace": "^6.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/node": "^25.9.0",
    "@types/vscode": "^1.120.0",
    "@vscode/vsce": "^3.9.1",
    "oxlint": "^1.66.0",
    "rimraf": "^6.1.3",
    "rollup": "^4.60.4",
    "rollup-plugin-conditional-compilation": "^2.1.4",
    "rollup-plugin-const-enum": "^2.0.0",
    "rollup-plugin-dts": "^6.4.1",
    "rollup-plugin-func-macro": "^1.2.3",
    "tsc-alias": "^1.8.17",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3"
  }
}