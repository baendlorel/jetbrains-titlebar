{
  "compilerOptions": {
    "target": "ESNext",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "resolveJsonModule": true,
    "resolvePackageJsonImports": true,
    "declaration": false,
    "esModuleInterop": true,
    "strict": true,
    "outDir": "out",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["./src/**/*.ts", "./tests/**/*.ts"]
}
